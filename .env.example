APP_NAME=Multimodal RAG Agent
APP_VERSION=0.2.0
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=*
REQUEST_TIMEOUT_SECONDS=30
IMAGE_SEARCH_INGEST_ENABLED=false
GENERAL_QA_BODY_RERANK_ENABLED=true
ALLOW_PLACEHOLDER_FALLBACK=true
LOCAL_RAG_STORE_MAX_DOCS=1000

# Optional connector endpoints (set when real services are ready)
# CRAWL4AI_ENDPOINT=http://127.0.0.1:11235/crawl
# CRAWL4AI_LOCAL_ENABLED=true
# CRAWL4AI_LOCAL_TIMEOUT_SECONDS=12
# SERPAPI_ENDPOINT=http://127.0.0.1:9001/search
# WEB_SEARCH_CANDIDATES_N=12
# WEB_URL_SELECT_M=5
# WEB_CRAWL_CONCURRENCY=3
# IMAGE_PROXY_MAX_REDIRECTS=5
# BGE_RERANKER_MODEL=BAAI/bge-reranker-base
# BGE_RERANKER_LOCAL_FILES_ONLY=false
# RAG_ANYTHING_ENDPOINT=http://127.0.0.1:9002
# RASA_ENDPOINT=http://127.0.0.1:5005/model/parse
# IMAGE_PIPELINE_ENDPOINT=http://127.0.0.1:9010/search-rank

# Image pipeline bridge runtime (used by scripts/start_image_pipeline.ps1)
# IMAGE_SEARCH_PROVIDER=serpapi
# IMAGE_TOP_K_DEFAULT=5
# IMAGE_CACHE_TTL_HOURS=72
# IMAGE_CACHE_CLEANUP_INTERVAL_SECONDS=1800
# IMAGE_RETRIEVAL_K=25
# IMAGE_SOURCE_MIN_ACCESSIBLE=10
# IMAGE_SOURCE_MAX_CHECK=30
# IMAGE_ACCESS_CHECK_CONCURRENCY=8
# IMAGE_ACCESS_CHECK_TIMEOUT=10
# IMAGE_CLIP_EVAL=20
# IMAGE_CLIP_DOWNLOAD_CONCURRENCY=6
# IMAGE_CLIP_KEEP=20
# IMAGE_CLIP_MIN_SCORE=0.18
# IMAGE_MULTI_QUERY_ENABLED=true
# IMAGE_MULTI_QUERY_MAX_VARIANTS=2
# IMAGE_FINAL_MAX_CHECK=15
# SERPAPI_API_KEYS=first_key,second_key
# SERPAPI_API_KEY=your_serpapi_key
# QWEN_API_KEY=sk-xxxx
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-plus
# QWEN_PARSER_MODEL=qwen3.5-plus
# PARSER_CACHE_MAX_ENTRIES=256
# QWEN_VLM_MODEL=qwen3.5-omni-plus-2026-03-15
# IMAGE_VLM_ANSWER_MAX=5
# CHINESE_CLIP_MODEL=OFA-Sys/chinese-clip-vit-base-patch16
# CHINESE_CLIP_LOCAL_FILES_ONLY=true

# RAGAnything bridge runtime (used by scripts/start_raganything_bridge.ps1)
# OPENAI_API_KEY=sk-xxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# RAGANYTHING_ADD_SCRIPTS_DIR_TO_PATH=true
# RAGANYTHING_WORKING_DIR=./raganything_storage
# RAGANYTHING_QUERY_MODE=hybrid
# RAGANYTHING_VISION_MODEL=qwen3.5-omni-plus-2026-03-15
# RAGANYTHING_FULL_INGEST_ENABLED=false

# Memory backend: memory | redis | mysql | hybrid
MEMORY_BACKEND=memory
MEMORY_MAX_TURNS=10

# Redis (used when MEMORY_BACKEND=redis/hybrid)
# REDIS_URL=redis://127.0.0.1:6379/0
REDIS_PREFIX=mmrag

# MySQL (used when MEMORY_BACKEND=mysql/hybrid)
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=change_me
# MYSQL_DATABASE=multimodal_rag

